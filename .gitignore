# 默认忽略所有文件/目录
*

# 允许推送的目录
!app/
!app/**
!cmd/
!cmd/**
!config/
!config/**
!data/
!data/**
!wizard/
!wizard/**
!scripts/
!scripts/**

# Runtime/generated artifacts (do not commit)
app/server/node_modules/
app/ui/frontend/node_modules/
app/var/app.db
app/var/app.db-shm
app/var/app.db-wal
app/var/thumbnails/
*.fpk

# 允许推送的根目录文件
!.dockerignore
!.fpkignore
!.gitignore
!.npmrc
!CHANGELOG.md
!Dockerfile
!ICON.PNG
!ICON_256.PNG
!README.md
!docker-compose.yml
!manifest
!markdown.svg
!build-fpk-multi-arch.sh


# Office editor assets (built separately, ~280MB, not for git)
app/office-editor/

# Generated PDF resources
app/ui/frontend/public/cmaps/
app/ui/frontend/public/standard_fonts/

# Backup/restore files
app/server/server.js.fpk_restored
app/ui/frontend/src/App.jsx.bak_final
app/ui/frontend/vite.config.js.bak
scripts/build-fpk-multi-arch.sh.bak

# Alternative package managers
app/ui/frontend/pnpm-lock.yaml
app/ui/frontend/pnpm-workspace.yaml

# Utility/deploy scripts (one-time use)
scripts/deploy-office-editor.sh
scripts/office-editor-api.mjs
scripts/serve-office.mjs
