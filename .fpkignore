
# ============================================
# 前端开发依赖（构建后不需要）
# ============================================
# 前端目录仅保留 dist，其他一律排除（显著减少安装扫描文件数）
app/ui/frontend/**
!app/ui/frontend/dist/
!app/ui/frontend/dist/**

# ============================================
# 后端开发文件
# ============================================
app/server/package.json
app/server/package-lock.json

# 后端 node_modules 中的文档和测试文件
app/server/node_modules/**/README.md
app/server/node_modules/**/LICENSE
app/server/node_modules/**/CHANGELOG.md
app/server/node_modules/**/test/
app/server/node_modules/**/tests/
app/server/node_modules/**/*.test.js
app/server/node_modules/**/*.spec.js
app/server/node_modules/**/example/
app/server/node_modules/**/examples/
app/server/node_modules/**/docs/
app/server/node_modules/**/.github/
# 避免安装阶段 chown 命中循环/异常符号链接
app/server/node_modules/.bin/
app/server/node_modules/.bin/**
# 运行时无需 TypeScript 编译器，剔除可减少包体与安装时长
app/server/node_modules/typescript/

# ============================================
# 构建脚本和开发工具
# ============================================
build*.sh
scripts/
快速打包
快速修复并部署.sh
deploy.sh
diagnose*.sh
diagnose*.js
test*.sh
test*.html
*.py

# ============================================
# 备份文件夹（397MB！）
# ============================================
backups/
app/shares/history/

# ============================================
# Git 相关
# ============================================
.git/
.gitignore
.github/

# ============================================
# IDE 和编辑器配置
# ============================================
.vscode/
.idea/
.cursor/
.lingma/
.trae/
*.swp
*.swo

# ============================================
# 临时文件
# ============================================
*.log
*.tmp
.DS_Store
node_modules/.cache/

# ============================================
